# Copy to .env for Docker Compose overrides. All values are optional.

# Standard defaults are 3000/8000. Use BACKEND_PORT=8004 if 8000 is busy locally.
FRONTEND_PORT=3000
BACKEND_PORT=8000

# Public URLs used by browsers, frontend broker redirects, and websocket clients.
# Broker browser callbacks should use:
#   ${NEXT_PUBLIC_APP_URL}/broker-connections
# Upstox notifier webhooks should use:
#   ${NEXT_PUBLIC_APP_URL}/api/broker-callbacks/upstox/notifier
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1
BETTER_AUTH_TRUSTED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
APP_PUBLIC_BASE_URL=http://localhost:8000

# Optional OAuth clients for hosted MCP connectors that do not support dynamic registration.
# Register redirect URI: ${NEXT_PUBLIC_APP_URL}/api/mcp/oauth/callback
MCP_GOOGLE_DRIVE_OAUTH_CLIENT_ID=
MCP_GOOGLE_DRIVE_OAUTH_CLIENT_SECRET=
MCP_SLACK_OAUTH_CLIENT_ID=
MCP_SLACK_OAUTH_CLIENT_SECRET=

# Optional: export backend LLM telemetry spans to any OTLP-compatible backend.
# Leave empty to keep telemetry local in Ananta's database only.
OTEL_SERVICE_NAME=ananta-market-stack-backend
OTEL_EXPORTER_OTLP_ENDPOINT=

# Optional. Docker Compose sets this to http://backend:8000/api/v1 automatically.
# Set it only when Next.js server actions need a different backend URL than browsers.
# MARKET_STACK_API_INTERNAL_URL=http://backend:8000/api/v1

# Optional first-run seed values. If left empty, Docker generates stable values.
# After the Docker config volume exists, the values in that volume are used.
# Do not change these for an existing install unless you are deliberately rotating secrets.
CREDENTIAL_ENCRYPTION_KEY=
BETTER_AUTH_SECRET=
REDIS_PASSWORD=

# Optional external Redis override.
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
# Optional external Redis URL for advanced hosted setups.
REDIS_URL=
