NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8000/api/v1
# Optional server-side override. If unset, server actions use NEXT_PUBLIC_API_BASE_URL.
# MARKET_STACK_API_INTERNAL_URL=http://127.0.0.1:8000/api/v1
MANASIJA_API_BASE_URL=https://developers.manasija.in

# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=
# Optional. Defaults to NEXT_PUBLIC_APP_URL.
# BETTER_AUTH_URL=http://localhost:3000
BETTER_AUTH_TRUSTED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# Optional. Defaults to ../backend/data/app.db from the frontend root (not process.cwd()).
# AUTH_DATABASE_PATH=../backend/data/app.db
