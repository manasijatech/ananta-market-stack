FROM python:3.12-slim

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PYTHONPATH=/app

WORKDIR /app

COPY backend/requirements.txt .
RUN grep -v '^winloop==' requirements.txt > requirements-linux.txt \
    && pip install --no-cache-dir -r requirements-linux.txt

COPY backend/ .
COPY docker/dev-backend-entrypoint.sh /usr/local/bin/ananta-market-stack-dev-backend-entrypoint
RUN sed -i 's/\r$//' /usr/local/bin/ananta-market-stack-dev-backend-entrypoint \
    && chmod +x /usr/local/bin/ananta-market-stack-dev-backend-entrypoint

EXPOSE 8000

ENTRYPOINT ["ananta-market-stack-dev-backend-entrypoint"]
CMD ["python", "-m", "uvicorn", "app.main:app", "--reload", "--host", "0.0.0.0", "--port", "8000"]
