FROM python:3.12-slim

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PYTHONPATH=/app \
    PIP_DEFAULT_TIMEOUT=100 \
    PIP_RETRIES=10 \
    PIP_DISABLE_PIP_VERSION_CHECK=1

WORKDIR /app

COPY requirements.txt .
# winloop is Windows-only; strip it for Linux images.
# Retry the install: Docker Desktop on Windows often hits transient PyPI
# failures ("No matching distribution found ... from versions: none").
RUN grep -v '^winloop==' requirements.txt > requirements-linux.txt \
    && pip install --no-cache-dir --upgrade pip \
    && ( \
         pip install --no-cache-dir --prefer-binary -r requirements-linux.txt \
         || (echo "pip install failed (attempt 1/5), retrying..." && sleep 5 \
             && pip install --no-cache-dir --prefer-binary -r requirements-linux.txt) \
         || (echo "pip install failed (attempt 2/5), retrying..." && sleep 10 \
             && pip install --no-cache-dir --prefer-binary -r requirements-linux.txt) \
         || (echo "pip install failed (attempt 3/5), retrying..." && sleep 15 \
             && pip install --no-cache-dir --prefer-binary -r requirements-linux.txt) \
         || (echo "pip install failed (attempt 4/5), retrying..." && sleep 20 \
             && pip install --no-cache-dir --prefer-binary -r requirements-linux.txt) \
       )

COPY . .
COPY dev-backend-entrypoint.sh /usr/local/bin/ananta-market-stack-dev-backend-entrypoint
RUN sed -i 's/\r$//' /usr/local/bin/ananta-market-stack-dev-backend-entrypoint \
    && chmod +x /usr/local/bin/ananta-market-stack-dev-backend-entrypoint

EXPOSE 8000

ENTRYPOINT ["ananta-market-stack-dev-backend-entrypoint"]
CMD ["python", "-m", "uvicorn", "app.main:app", "--host", "0.0.0.0", "--port", "8000", "--reload"]
