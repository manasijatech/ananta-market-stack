# Copy to .env and adjust. Never commit real secrets.

# SQLite database file (relative to process cwd)
DATABASE_URL=sqlite:///./data/app.db
APP_PUBLIC_BASE_URL=http://localhost:8000

# Redis for cached quote snapshots (optional; failures are logged only)
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_QUOTE_TTL_SECONDS=30

# Fernet key for encrypting broker secrets at rest (required unless dev flag below)
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
CREDENTIAL_ENCRYPTION_KEY="UD0HkB-v32d9ILzSxnuYPaJ5Lh2ssIAiPORcxdakaO8="

# Only for local development without a Fernet key (uses a built-in dev key — insecure)
ALLOW_INSECURE_DEV_CREDENTIALS=false

# Avoids clashing with generic DEBUG env vars from other tools
APP_DEBUG=false
