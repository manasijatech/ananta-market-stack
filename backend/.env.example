# Copy to .env and adjust. Never commit real secrets.

# SQLite database file (relative to process cwd)
DATABASE_URL=sqlite:///./data/app.db
APP_PUBLIC_BASE_URL=http://localhost:8000

# Redis for cached quote snapshots (optional; failures are logged only)
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_QUOTE_TTL_SECONDS=30
REDIS_LIVE_PRICE_TTL_SECONDS=1800

# Fernet key for encrypting broker secrets at rest (required unless dev flag below).
# Generate locally; never commit a real key:
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
CREDENTIAL_ENCRYPTION_KEY=

# Only for local development without a Fernet key (uses a built-in dev key — insecure)
ALLOW_INSECURE_DEV_CREDENTIALS=false

# Avoids clashing with generic DEBUG env vars from other tools
APP_DEBUG=false

# Debug file logging. When LOG_TO_FILE is unset, APP_DEBUG=true enables this automatically.
# The file is rotated before it grows beyond LOG_FILE_MAX_BYTES.
LOG_TO_FILE=
LOG_FILE_PATH=./data/logs/backend-debug.log
LOG_FILE_MAX_BYTES=52428800
LOG_FILE_BACKUP_COUNT=3
LOG_LEVEL=

# Optional: export in-process LLM telemetry spans to any OTLP-compatible backend.
# Local LLM usage/cost telemetry is still stored in SQLite when this is unset.
OTEL_SERVICE_NAME=ananta-market-stack-backend
OTEL_EXPORTER_OTLP_ENDPOINT=
