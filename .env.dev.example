# Copy to .env.dev for Docker Compose Watch development.
#   cp .env.dev.example .env.dev
#   docker compose -f docker-compose.dev.yml watch

FRONTEND_PORT=3000
BACKEND_PORT=8000

NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8000/api/v1
APP_PUBLIC_BASE_URL=http://localhost:8000
BETTER_AUTH_URL=http://localhost:3000
BETTER_AUTH_TRUSTED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Optional OAuth clients for Google Drive/Slack MCP one-click connect.
# Register redirect URI: ${NEXT_PUBLIC_APP_URL}/api/mcp/oauth/callback
MCP_GOOGLE_DRIVE_OAUTH_CLIENT_ID=
MCP_GOOGLE_DRIVE_OAUTH_CLIENT_SECRET=
MCP_SLACK_OAUTH_CLIENT_ID=
MCP_SLACK_OAUTH_CLIENT_SECRET=

# Optional. Leave empty to use the dev-only insecure Fernet fallback in Compose.
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
CREDENTIAL_ENCRYPTION_KEY=

# Auth signing secret. Generate: openssl rand -base64 32
# If empty, Compose uses a local-only placeholder for first boot.
BETTER_AUTH_SECRET=

APP_DEBUG=true
ALLOW_INSECURE_DEV_CREDENTIALS=true
